# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# sqlc generated files
sqlc/*.go

# Database
*.db
*.db-shm
*.db-wal
/database/*.db

# Air live reload
/tmp/
tmp/

# Editor/IDE
# .idea/
# .vscode/

# Build artifacts
/main
/server

# Agent / MCP / IDE artifacts
.playwright-mcp/
.windsurf/

# Frontend
frontend/node_modules/
frontend/dist/
.env.local
.env.*.local

# Embedded frontend build (populated at build time; README kept for go:embed)
cmd/server/dist/*
!cmd/server/dist/README.md

# Generated swagger docs
docs/docs.go
docs/swagger.json
docs/swagger.yaml
cmd/server/docs/

# Build binaries (ensure tracked ones are removed)
main
server
bin/
