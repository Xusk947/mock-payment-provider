# Server Configuration
SERVER_PORT=3000
SERVER_HOST=localhost

# Public base URL for generating checkout/payment links (e.g. https://mock-payment.example.com)
# If empty, falls back to http://localhost:{SERVER_PORT}
PUBLIC_BASE_URL=

# Database Configuration
DATABASE_PATH=./database/payments.db

# Logger Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Security Configuration
JWT_SECRET=your-secret-key-here
API_KEY_HEADER=X-API-Key

# 3D Secure Configuration
THREEDS_ENABLED=true
THREEDS_CHALLENGE_URL=https://3ds.example.com/challenge

# Webhook Configuration
WEBHOOK_TIMEOUT=30s
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5s